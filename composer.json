{
    "name": "rhino-project/rhino-laravel",
    "description": "Automatic REST API generation for Laravel Eloquent models with built-in security, validation, and advanced querying",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/rhino-project/rhino-laravel",
    "keywords": ["laravel", "api", "crud", "rest", "multi-tenant", "eloquent", "rhino"],
    "authors": [
        {
            "name": "Bruno Cipolla",
            "email": "bruno@codalio.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "spatie/laravel-query-builder": "^6.2",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "laravel/sanctum": "^4.0",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Rhino\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rhino\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rhino\\GlobalControllerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
